{
  "name": "credit-request-system-root",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "install:all": "npm install --prefix ./packages/shared && npm install --prefix ./apps/backend && npm install --prefix ./apps/frontend",
    "dev:backend": "npm --prefix ./apps/backend run dev",
    "dev:frontend": "npm --prefix ./apps/frontend run dev",
    "dev": "echo 'Run backend and frontend in separate terminals:' && echo 'npm run dev:backend' && echo 'npm run dev:frontend'",
    "lint": "eslint . --ext .ts,.tsx --fix || true",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "backend:dev": "npm --prefix ./apps/backend run dev",
    "frontend:dev": "npm --prefix ./apps/frontend run dev",
    "producer:dev": "npm --prefix ./apps/backend run queue:producer",
    "worker:dev": "npm --prefix ./apps/backend run queue:worker",
    "dev:all": "concurrently \"npm run backend:dev\" \"npm run frontend:dev\" \"npm run producer:dev\" \"npm run worker:dev\"",
    "db:migrate": "npm --prefix ./apps/backend run migrate",
    "setup": "npm install && npm run db:migrate"
  },
  "dependencies": {
    "bullmq": "^5.71.0",
    "ioredis": "^5.10.0"
  },
  "devDependencies": {
    "concurrently": "^7.6.0"
  }
}
